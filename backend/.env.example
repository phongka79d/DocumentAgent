APP_ENV=development
SINGLE_USER_ID=single_user
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=documents
SHOPAIKEY_API_KEY=shopaikey-placeholder
SHOPAIKEY_BASE_URL=https://api.shopaikey.com/v1
SHOPAIKEY_EMBEDDING_MODEL=text-embedding-ada-002
QDRANT_URL=https://example-cluster.qdrant.io
QDRANT_API_KEY=qdrant-placeholder
QDRANT_COLLECTION=document_chunks
MAX_UPLOAD_BYTES=25000000
CHUNK_SIZE_TOKENS=1000
CHUNK_OVERLAP_TOKENS=150
FRONTEND_ORIGIN=http://localhost:5173
